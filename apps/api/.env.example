# ── apps/api environment ─────────────────────────────────────────────────────
# Copy to `apps/api/.env` and fill in. Prisma and NestJS both read THIS file.

# Database (SQLite). File path is relative to apps/api/prisma/.
# No server to install — the file is created by `npm run db:migrate`.
DATABASE_URL="file:./dev.db"

# API server
API_PORT=3000
API_PREFIX=api
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173

# Auth / JWT — generate strong secrets:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_TTL=1h
JWT_REFRESH_SECRET="change-me-refresh-secret"
# How long a user stays signed in (refresh token + cookie lifetime). Slides forward on use.
JWT_REFRESH_TTL=15d
REFRESH_COOKIE_NAME=oms_rt

# Bootstrap admin created by `npm run db:seed`
SEED_ADMIN_EMAIL=admin@oms.local
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=System Administrator
# Optional quick-login PIN (4–6 digits) for the bootstrap admin.
SEED_ADMIN_PIN=246813
