// OMS data model — SQLite.
// Run `npm run db:migrate` to create/update tables, `npm run db:seed` to load
// the permission catalog, system roles and the bootstrap admin user.
//
// SQLite notes (vs MySQL/Postgres): no native enums, no Json type, no native
// type attributes (@db.Text). So `status` is a validated String, `metadata` /
// `Setting.value` hold JSON-serialized strings. To move to MySQL/Postgres later:
// change the provider below, restore an enum for status and `Json` columns, and
// re-migrate.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Identity & access control ───────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  // Optional 4–6 digit quick-login PIN (bcrypt-hashed). Null = PIN login disabled.
  pinHash      String?
  // One of: 'active' | 'disabled' | 'invited' (enforced by the API via class-validator).
  status       String   @default("active")
  // Bumping tokenVersion invalidates every outstanding access token for the user.
  tokenVersion Int      @default(0)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles             UserRole[]
  refreshTokens     RefreshToken[]
  pushSubscriptions PushSubscription[]
  auditLogs         AuditLog[]

  @@index([status])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  // Stable machine name, e.g. 'super_admin'.
  name        String   @unique
  label       String
  description String?
  // System roles cannot be deleted from the UI.
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(cuid())
  // Permission key, e.g. 'order:create'.
  key       String   @unique
  resource  String
  action    String
  label     String
  group     String
  createdAt DateTime @default(now())

  roles RolePermission[]

  @@index([resource])
  @@map("permissions")
}

// Explicit join: User <-> Role (kept explicit so we can add assignedAt/assignedBy later).
model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// Explicit join: Role <-> Permission.
model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// Hashed refresh tokens enable rotation + server-side revocation (logout / "log out everywhere").
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?
  ip        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// One row per device's Web Push subscription — lets a broadcast reach a
// device even when the app is fully closed.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ── Audit trail: who did what, when, from where ─────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  action     String
  resource   String
  resourceId String?
  description String?
  method     String?
  path       String?
  statusCode Int?
  ip         String?
  userAgent  String?
  // JSON-serialized before/after snapshot (SQLite has no native Json type).
  metadata   String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resource])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── App settings (key/value, surfaced on the Settings screen) ───────────────

model Setting {
  key       String   @id
  // JSON-serialized value (SQLite has no native Json type).
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ── Sales: Customers & Transporters ─────────────────────────────────────────

model Transporter {
  // Integer PK to match the legacy TID and ease data import.
  id        Int      @id @default(autoincrement())
  // Auto-generated human-readable code (e.g. TRN-00001). Set by the API on create;
  // never required on import (it is derived server-side), shown on export.
  code      String?  @unique
  name      String   @unique
  packing   Float?
  freight   Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers  Customer[]
  transRates TransRate[]

  @@map("transporters")
}

// Sales agents (used when partySource = AGENT). Maintained as its own master so
// agents can be added on the fly from the customer form and tracked with timestamps.
model Agent {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  contactNo String?
  state     String?
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agents")
}

model Customer {
  // Integer PK to match the legacy CUSTOMER.ID and ease data import.
  id            Int      @id @default(autoincrement())
  // Auto-generated human-readable code (e.g. CUST-00001). Set by the API on create;
  // never required on import (it is derived server-side), shown on export.
  code          String?  @unique
  partySource   String?
  agentName     String?
  category      String?
  partyName     String?
  billingRate   Float?
  // FK to Transporter; transportName/packing/freight are kept as a snapshot too
  // (the legacy form stored them on the customer row).
  transporterId Int?
  transportName String?
  bagName       String?
  packing       Float?
  freight       Float?
  boxRate       Int?
  creditPeriod  Int?
  city          String?
  state         String?
  region        String?
  mobile        String?
  email         String?
  brand         String?
  billRatePc    Float?
  payBy         String?
  // TDS: whether tax is deducted at source for this customer, and at what %.
  tdsApplicable Boolean  @default(false)
  tdsPercent    Float?
  // Active parties show in every picker; inactive ones are hidden from dropdowns
  // (but kept for history + visible on the Customers master via a status filter).
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transporter Transporter? @relation(fields: [transporterId], references: [id], onDelete: SetNull)
  gstRates    GstRate[]
  transRates  TransRate[]
  rateOverrides    CustomerRate[]
  logoRestrictions CustomerLogoRestriction[]
  bagWeights       CustomerBagWeight[]

  @@index([partyName])
  @@index([agentName])
  @@index([category])
  @@index([transporterId])
  @@map("customers")
}

// ── Customer "Special Rates" (legacy Form10) ──────────────────────────────────
// A per-customer rate DELTA added on top of the base product / design rate. The
// effective rate is resolved most-specific-first (ITEM → SUBCATEGORY → CATEGORY);
// only the first matching level applies. Replaces the 6 legacy tables
// (SPRODUCT/SCSPRODUCT/SCPRODUCT for products, SDESIGN/SCSDESIGN/SCDESIGN for
// designs) with one table keyed by (kind, scope). Unused levels are stored as ''
// (not null) so the composite unique key works on SQLite.
model CustomerRate {
  id          Int      @id @default(autoincrement())
  customerId  Int
  // 'PRODUCT' (adjusts the product rate) or 'DESIGN' (adjusts the design rate).
  kind        String
  // 'CATEGORY' | 'SUBCATEGORY' | 'ITEM' (specificity level).
  scope       String
  category    String
  subCategory String   @default("") // '' when scope = CATEGORY
  // Product name (kind PRODUCT) or design type (kind DESIGN); '' unless scope = ITEM.
  target      String   @default("")
  // Rate delta — may be negative (a discount).
  rate        Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, kind, scope, category, subCategory, target])
  @@index([customerId])
  @@map("customer_rates")
}

// Per-customer bag weight: for this customer + product category, one bag weighs
// `kgsPerBag` kgs. The order form auto-fills Kgs = Bags × kgsPerBag as bags are typed.
model CustomerBagWeight {
  id         Int      @id @default(autoincrement())
  customerId Int
  category   String
  kgsPerBag  Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, category])
  @@index([customerId])
  @@map("customer_bag_weights")
}

// A per-customer logo restriction: the logo is NOT ALLOWED for the given category
// (or category + sub-category). Replaces SP_CATEGORY_LOGO / SP_SUBCATEGORY_LOGO.
model CustomerLogoRestriction {
  id          Int      @id @default(autoincrement())
  customerId  Int
  // 'CATEGORY' | 'SUBCATEGORY'.
  scope       String
  category    String
  subCategory String   @default("") // '' when scope = CATEGORY
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, scope, category, subCategory])
  @@index([customerId])
  @@map("customer_logo_restrictions")
}

/// Audit trail of GST / transport rate changes so past rates stay visible.
/// One row per change (old -> new). `kind` is 'GST' or 'TRANS'.
model RateHistory {
  id            Int      @id @default(autoincrement())
  kind          String
  customerName  String
  category      String
  type          String? // transport only
  transportName String? // transport only
  oldRate       Int?
  newRate       Int?
  changedByName String?
  changedAt     DateTime @default(now())

  @@index([kind, customerName, category])
  @@index([changedAt])
  @@map("rate_history")
}

// Per-customer, per-product-category GST rate.
model GstRate {
  id           Int      @id @default(autoincrement())
  customerId   Int?
  // Stable customer code (e.g. CUST-00001) — the fast link to the customer master.
  customerCode String?
  customerName String
  // Product category (legacy PCATEGORY), stored uppercase.
  category     String
  rate         Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([customerName, category])
  @@index([customerId])
  @@index([customerCode])
  @@map("gst_rates")
}

// Per-customer transport rate, keyed by category + type + transporter.
model TransRate {
  id            Int      @id @default(autoincrement())
  customerId    Int?
  // Stable customer code (e.g. CUST-00001) — the fast link to the customer master.
  customerCode  String?
  customerName  String
  category      String
  type          String
  transporterId Int?
  transportName String?
  rate          Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  transporter Transporter? @relation(fields: [transporterId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([customerCode])
  @@index([transporterId])
  @@map("trans_rates")
}

// ── Catalog: Products, Designs & Combinations ───────────────────────────────

model Product {
  id          Int      @id @default(autoincrement())
  // Auto-generated code (e.g. PRD-00001).
  code        String?  @unique
  category    String
  subCategory String
  product     String
  size        Float?
  weight      Float?
  pcs         Float?
  rate        Float?
  // Active products show in the order item pickers; inactive ones are hidden but kept.
  active         Boolean  @default(true)
  // Whether this product appears on the customer Rate List.
  showOnRateList Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // A product is uniquely identified by category + sub-category + product + size.
  @@unique([category, subCategory, product, size])
  @@index([category])
  @@index([product])
  @@map("products")
}

model Design {
  id          Int      @id @default(autoincrement())
  // Auto-generated code (e.g. DSG-00001).
  code        String?  @unique
  category    String
  subCategory String
  designType  String
  cost        Float?
  rate        Float?
  // Active designs show in the order item pickers; inactive ones are hidden but kept.
  active         Boolean  @default(true)
  // Whether this design appears on the customer Rate List.
  showOnRateList Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  combinationLinks CombinationDesign[]

  @@unique([category, subCategory, designType])
  @@index([category])
  @@map("designs")
}

// Lookup: maps a design-type code to one or more human-readable names.
// A single code can have several names (one-to-many), so the natural key is the
// (designType, designName) pair, not the code alone.
model DesignName {
  id         Int      @id @default(autoincrement())
  designType String
  designName String
  /// Path relative to the /uploads root, e.g. "design-names/<uuid>.jpg" — a
  /// reference photo so the right design is recognisable at a glance.
  photoPath  String?
  /// Same-origin URL the web app loads, e.g. "/api/uploads/design-names/<uuid>.jpg".
  photoUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([designType, designName])
  @@index([designType])
  @@map("design_names")
}

model Combination {
  id        Int      @id @default(autoincrement())
  // Auto-generated code (e.g. CMB-00001).
  code      String?  @unique
  // Display name, auto-built by joining the component design types (editable).
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  designLinks CombinationDesign[]

  @@map("combinations")
}

// A combination is built from one or more designs. The link lets us recompute
// the combination's cost/rate whenever a constituent design's cost changes.
model CombinationDesign {
  combinationId Int
  designId      Int

  combination Combination @relation(fields: [combinationId], references: [id], onDelete: Cascade)
  design      Design      @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@id([combinationId, designId])
  @@index([designId])
  @@map("combination_designs")
}

// ── Orders ──────────────────────────────────────────────────────────────────

/// A sales order header. One order has many line items.
model Order {
  id             Int       @id @default(autoincrement())
  // Auto-generated human-readable order number (e.g. ORD-00001).
  code           String?   @unique
  // Customer's purchase-order number (free text, optional).
  poNumber       String?
  customerId     Int?
  customerName   String
  agentName      String?
  category       String? // e.g. SALES
  orderDate      DateTime  @default(now())
  completionDate DateTime?
  completionDay  Int?
  priority       String? // URGENT / NORMAL
  status         String    @default("PENDING") // CONFIRMED / PENDING / CANCELLED
  ordType        String    @default("SALES ORDER")
  comment        String?
  userName       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  items OrderItem[]

  // Set when this order was created by converting a quotation.
  fromQuotation Quotation? @relation("OrderFromQuotation")
  dispatches    Dispatch[]

  @@index([customerId])
  @@index([status])
  @@index([orderDate])
  @@map("orders")
}

/// A sales quotation — same shape as an order, with its own QUO-##### numbering
/// and a lifecycle: DRAFT/SENT → CONVERTED (to an order) or CANCELLED (with a
/// tracked reason for analysis).
model Quotation {
  id             Int       @id @default(autoincrement())
  code           String?   @unique // QUO-#####
  poNumber       String?
  customerId     Int?
  customerName   String
  agentName      String?
  category       String?
  quotationDate  DateTime  @default(now())
  completionDate DateTime?
  completionDay  Int?
  priority       String?
  status         String    @default("DRAFT") // DRAFT / SENT / CONVERTED / CANCELLED
  ordType        String    @default("QUOTATION")
  comment        String?
  userName       String?

  // "Sent to customer" tracking.
  sentAt     DateTime?
  sentByName String?

  // Conversion tracking — links to the order this quotation became.
  convertedOrderId Int?      @unique
  convertedOrder   Order?    @relation("OrderFromQuotation", fields: [convertedOrderId], references: [id])
  convertedAt      DateTime?
  // How it was converted: DIRECT (as-is) or EDITED (changed first).
  convertMode      String?

  // Cancellation tracking — why it was cancelled, for analysis.
  cancelReason    String?
  cancelNote      String?
  cancelledAt     DateTime?
  cancelledByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items QuotationItem[]

  @@index([customerId])
  @@index([status])
  @@index([quotationDate])
  @@map("quotations")
}

/// A single line item on a quotation (mirrors OrderItem).
model QuotationItem {
  id          Int      @id @default(autoincrement())
  quotationId Int
  pCategory   String?
  subCategory String?
  product     String?
  design      String?
  productName String?
  designType  String?
  psize       Float?
  bags        Float?
  pcs         Float?
  gram        Float?
  box         Float?
  productRate Float?
  designRate  Float?
  rate        Float?
  calField    String?
  priority    String?
  ordType     String?
  comment     String?
  createdAt   DateTime @default(now())

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@map("quotation_items")
}

/// A single line item on an order (a product × design + quantities + rates).
model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  pCategory   String? // product category (GLASS / CUP / …)
  subCategory String?
  product     String?
  design      String?
  productName String? // composite display name (e.g. "10 PLAIN")
  designType  String?
  psize       Float?
  bags        Float?
  pcs         Float?
  gram        Float?
  box         Float?
  productRate Float?
  designRate  Float?
  rate        Float? // total = productRate + designRate
  calField    String? // pricing unit: KGS / PCS
  priority    String? // URGENT / NORMAL (per line item)
  ordType     String? // order type (e.g. SALES ORDER)
  // Per-line status: CONFIRMED (active) or CANCELLED (kept for the record, excluded
  // from order totals and not dispatchable). Mirrors legacy ORDERTBL.STATUS.
  status      String   @default("CONFIRMED")
  comment     String?
  // Soft link to the bag Booking this line was converted from (null for normal lines).
  bookingId   Int?
  createdAt   DateTime @default(now())

  order      Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dispatches Dispatch[]
  photos     OrderItemPhoto[]

  @@index([orderId])
  @@index([bookingId])
  @@map("order_items")
}

/// A photo attached to an order line (reference image, artwork, packing shot…).
/// The file lives on disk under the project's /uploads folder; only its path +
/// served URL are stored here. Visible/editable from Order, Order Modify and
/// Dispatch — all keyed on the same order line.
model OrderItemPhoto {
  id          Int      @id @default(autoincrement())
  orderItemId Int
  /// Path relative to the /uploads root, e.g. "order-items/<uuid>.jpg".
  path        String
  /// Same-origin URL the web app loads, e.g. "/api/uploads/order-items/<uuid>.jpg".
  url         String
  filename    String? // original upload name (for download / display)
  mimeType    String?
  size        Int? // bytes
  uploadedBy  String? // user name/email that uploaded it
  createdAt   DateTime @default(now())

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@map("order_item_photos")
}

/// A single dispatch (shipment) of an order line — partial or full. The pending
/// quantity of a line = ordered − Σ(dispatched). Mirrors the legacy DispatchTbl.
model Dispatch {
  id          Int     @id @default(autoincrement())
  code        String? @unique // DSP-#####
  orderItemId Int
  orderId     Int
  orderCode   String? // the parent order's human code (snapshot)

  // Snapshot of the line at dispatch time.
  customerId   Int?
  customerName String
  agentName    String?
  category     String?
  pCategory    String?
  subCategory  String?
  product      String?
  productName  String?
  designType   String?
  psize        Float?
  priority     String?
  calField     String?
  ordType      String?
  productRate  Float?
  designRate   Float?
  rate         Float?

  // Dispatched quantities.
  bags Float?
  pcs  Float?
  gram Float?
  box  Float?

  dispatchStatus String   @default("PARTIAL") // PARTIAL / FULL
  dispatchDate   DateTime @default(now())
  comment        String?
  supItem        String?
  userName       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([orderId])
  @@index([dispatchStatus])
  @@map("dispatches")
}

// ── Challan / Tax-Invoice (legacy PendChallan + Form14) ───────────────────────
// A challan is a tax invoice built from one customer's dispatched-but-not-yet-
// challaned lines. Header (InvTbl) + items (ChallanTbl). Pricing engine (freight/
// packing/pouch/GST/half-bill/TCS) + PDF print land in Phase 2.
model Challan {
  id              Int       @id @default(autoincrement())
  // Human invoice number, e.g. "SSS/26-27/01" (legacy InvNo).
  code            String    @unique
  prefix          String?
  invDate         DateTime  @default(now())
  invTime         String?
  customerId      Int?
  customerName    String
  billingAddress  String?
  shippingAddress String?
  category        String?
  paymentTerm     Int?
  dueDate         DateTime?
  transName       String?
  // Charges & totals (computed by the Phase-2 pricing engine).
  packing         Float?
  freight         Float?
  pouch           Float?
  tcs             Float?
  // TDS deducted at source (when the party is TDS-applicable): amount + the % used.
  tds             Float?
  tdsPercent      Float?
  tax             Float? // GST amount
  total           Float?
  b               Float? // billed portion
  c               Float? // balance (total - b)
  remarks         String?
  gst             Float? // GST rate %
  freightRate     Float?
  packingRate     Float?
  billingRate     Float?
  bpcRate         Float?
  noBill          Boolean   @default(false)
  transaction     String    @default("SALES INVOICE")
  // CONFIRMED / CANCELLED.
  challanStatus   String    @default("CONFIRMED")
  userName        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  items ChallanItem[]

  @@index([customerName])
  @@index([invDate])
  @@map("challans")
}

// Gaps in a prefix/FY invoice-number series that were explicitly acknowledged
// ("dismissed") by an operator, so they stop showing on the Missing Challan
// list. recycledAt set = restored back onto the missing list.
model ChallanMissingLog {
  id         Int       @id @default(autoincrement())
  prefix     String
  fy         String
  invNo      Int
  // Why this number was skipped (e.g. "voided by hand", "duplicate order") —
  // required at dismiss time so it means something on the "Show Deleted Only" list.
  reason     String?
  deletedAt  DateTime  @default(now())
  recycledAt DateTime?

  @@index([prefix, fy])
  @@map("challan_missing_log")
}

model ChallanItem {
  id          Int      @id @default(autoincrement())
  challanId   Int
  // Source dispatch line (null/0 for SCRAP or manual rows). Plain int — used to
  // decide which dispatches are still "pending challan".
  dispatchId  Int?
  productName String?
  design      String?
  bags        Float?
  pcs         Float?
  kgs         Float?
  box         Float?
  unit        String?
  price       Float?
  amount      Float?
  pCategory   String?
  comment     String?
  userName    String?
  createdAt   DateTime @default(now())

  challan Challan @relation(fields: [challanId], references: [id], onDelete: Cascade)

  @@index([challanId])
  @@index([dispatchId])
  @@map("challan_items")
}

/// Credit Note header (legacy InvTblR). Kept in its own table — like the legacy —
/// so credit notes never count as pending sales. A CN posts a CREDIT NOTE ledger
/// row and clears opening balance → pending invoices FIFO → parks the rest as a
/// party advance. code = "CN/<n>". Debit Notes, by contrast, live in `Challan`
/// (prefix='DN', transaction='DEBIT NOTE') because a DN *is* a pending debit.
model CreditNote {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  prefix          String    @default("CN")
  invDate         DateTime  @default(now())
  invTime         String?
  customerId      Int?
  customerName    String
  billingAddress  String?
  shippingAddress String?
  category        String?
  paymentTerm     Int?
  dueDate         DateTime?
  transName       String?
  packing         Float?
  freight         Float?
  pouch           Float?
  tax             Float? // GST amount
  total           Float?
  b               Float? // bank portion
  c               Float? // cash portion
  remarks         String?
  gst             Float? // GST rate %
  freightRate     Float?
  packingRate     Float?
  billingRate     Float?
  bpcRate         Float?
  noBill          Boolean   @default(false)
  status          String    @default("CREDIT NOTE")
  userName        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  items CreditNoteItem[]

  @@index([customerName])
  @@index([customerId])
  @@index([invDate])
  @@map("credit_notes")
}

model CreditNoteItem {
  id           Int      @id @default(autoincrement())
  creditNoteId Int
  // Source dispatch line the return refers to (0/null for manual rows).
  dispatchId   Int?
  // Original sale invoice this line credits against (legacy ChallanTblR.[Ref InvNo]).
  refInvNo     String?
  productName  String?
  design       String?
  bags         Float?
  pcs          Float?
  kgs          Float?
  box          Float?
  unit         String?
  price        Float?
  amount       Float?
  pCategory    String?
  comment      String?
  userName     String?
  createdAt    DateTime @default(now())

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId])
  @@index([dispatchId])
  @@map("credit_note_items")
}

/// User-editable option lists (e.g. completion-day choices, order types),
/// grouped by `group`. Managed from the Settings page.
model OrderOption {
  id        Int      @id @default(autoincrement())
  group     String // COMPLETION_DAYS / ORDER_TYPE / …
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([group, value])
  @@index([group])
  @@map("order_options")
}

/// Singleton key/value app configuration (e.g. company name, company logo data URL).
model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_config")
}

/// CRM follow-up: one commitment to a party (delivery or payment). Carries a
/// promised date + a reminder loop that re-surfaces it until resolved.
model Followup {
  id         Int      @id @default(autoincrement())
  kind       String   @default("DELIVERY") // DELIVERY | PAYMENT
  customerId Int?
  partyName  String // always set (free text when the customer isn't in the system)
  orderId    Int?
  orderCode  String?
  orderItemId Int?
  itemText   String? // free item text when no linked order line
  title      String
  detail     String?
  stage      String? // POLISHING | SUPPLIER | DISPATCH | READY | free text
  priority   String   @default("NORMAL")
  status     String   @default("OPEN") // OPEN | DONE | CANCELLED
  promisedAt DateTime?
  // Reminder loop (fall back to CRM defaults when null).
  reminderIntervalMins Int?
  maxRemindersPerDay   Int?
  remindersToday       Int      @default(0)
  remindersDate        String? // yyyy-mm-dd the counter applies to (resets daily)
  nextRemindAt         DateTime?
  lastRemindedAt       DateTime?
  pushSentAt DateTime? // set once a push has fired for the current due-cycle; cleared on re-promise/snooze/reopen
  createdByName String?
  resolvedByName String?
  resolvedAt    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  logs      FollowupLog[]
  checklist FollowupChecklistItem[]

  @@index([status])
  @@index([kind])
  @@index([partyName])
  @@index([promisedAt])
  @@index([customerId])
  @@map("followups")
}

/// A tick-off task on a follow-up. Added by typing or by voice (Gemini turns
/// spoken Hindi/English into short checklist items).
model FollowupChecklistItem {
  id         Int      @id @default(autoincrement())
  followupId Int
  text       String
  done       Boolean  @default(false)
  sortOrder  Int      @default(0)
  /// 'MANUAL' | 'VOICE' — how the item was added.
  source     String   @default("MANUAL")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  followup Followup @relation(fields: [followupId], references: [id], onDelete: Cascade)

  @@index([followupId])
  @@map("followup_checklist_items")
}

/// One timeline entry on a follow-up (a note / ack / snooze / re-promise).
model FollowupLog {
  id           Int      @id @default(autoincrement())
  followupId   Int
  kind         String   @default("NOTE") // NOTE | ACK | SNOOZE | PROMISE | STATUS
  note         String?
  stage        String?
  newPromisedAt DateTime?
  userName     String?
  createdAt    DateTime @default(now())

  followup Followup @relation(fields: [followupId], references: [id], onDelete: Cascade)

  @@index([followupId])
  @@map("followup_logs")
}

/// A bag booking: a customer reserves quantity (bags + kgs) without naming items.
/// The rates are frozen at `bookingDate`; later it's converted into real order
/// lines (in parts). `rateSnapshot` captures the customer's special-rate rows at
/// booking time so the effective rate can be reproduced exactly on conversion.
model Booking {
  id            Int      @id @default(autoincrement())
  code          String?  @unique // BKG-00001
  customerId    Int?
  customerName  String
  agentName     String?
  category      String? // SALES etc.
  bookingDate   DateTime @default(now()) // the rate-basis date
  bags          Float    @default(0) // total booked
  kgs           Float    @default(0) // total booked (weight)
  convertedBags Float    @default(0) // drawn down by conversions
  convertedKgs  Float    @default(0)
  status        String   @default("OPEN") // OPEN | PARTIALLY_CONVERTED | CONVERTED | CANCELLED
  comment       String?
  orderId       Int? // the Order holding converted lines (created lazily)
  // JSON of the customer's { rates, logos } special-rate rows captured at booking.
  rateSnapshot  String?
  userName      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  conversions BookingConversion[]

  @@index([customerId])
  @@index([status])
  @@index([bookingDate])
  @@map("bookings")
}

/// Audit of one conversion step: which items were pulled from a booking, the
/// booking-date rate used, and the order line created.
model BookingConversion {
  id              Int      @id @default(autoincrement())
  bookingId       Int
  orderItemId     Int?
  productName     String?
  designType      String?
  bags            Float?
  kgs             Float?
  pcs             Float?
  box             Float?
  frozenRate      Float? // the effective rate as of the booking date
  amount          Float?
  convertedByName String?
  convertedAt     DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_conversions")
}

/// Every change to a product's chart rate (old -> new). Powers "rate as of date"
/// for bag-booking conversion + an auditable price-change trail.
model ProductRateHistory {
  id            Int      @id @default(autoincrement())
  productId     Int
  productName   String
  category      String
  subCategory   String
  size          Float?
  oldRate       Float?
  newRate       Float?
  changedByName String?
  changedAt     DateTime @default(now())

  @@index([productId])
  @@index([changedAt])
  @@map("product_rate_history")
}

/// Every change to a design's rate (old -> new).
model DesignRateHistory {
  id            Int      @id @default(autoincrement())
  designId      Int
  designType    String
  category      String
  subCategory   String
  oldRate       Float?
  newRate       Float?
  changedByName String?
  changedAt     DateTime @default(now())

  @@index([designId])
  @@index([changedAt])
  @@map("design_rate_history")
}

/// Every change to a per-customer special-rate override (old -> new; null = removed).
model CustomerRateHistory {
  id            Int      @id @default(autoincrement())
  customerId    Int
  customerName  String?
  kind          String // PRODUCT | DESIGN
  scope         String
  category      String
  subCategory   String
  target        String
  oldRate       Float?
  newRate       Float?
  changedByName String?
  changedAt     DateTime @default(now())

  @@index([customerId])
  @@index([changedAt])
  @@map("customer_rate_history")
}

// ── Accounts: Cheque management ─────────────────────────────────────────────

/// Company bank accounts (legacy SETTING_BANK_NAME). The Manage Cheques form's
/// "deposit bank" picker shows "BANK NAME-<last 4 of A/C>".
model BankAccount {
  id        Int      @id @default(autoincrement())
  bankName  String
  acNo      String
  ifsc      String?
  branch    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bankName, acNo])
  @@map("bank_accounts")
}

/// A received cheque and its lifecycle (legacy ACCT MANAGE CHEQUE):
/// PENDING → DEPOSITED → CLEARED | BOUNCED. Deposit is only allowed on/after the
/// due date. A bounced cheque may be re-deposited (isRepresent).
model Cheque {
  id            Int       @id @default(autoincrement())
  // Snapshot of the party + FK to the customer (legacy CUS ID).
  customerId    Int?
  partyName     String
  chequeNo      String
  chequeAmt     Float
  // Party's/payer's bank (free text) and our deposit bank ("BANK NAME-1234").
  payeeBank     String?
  drawerBank    String?
  recDate       DateTime  @default(now())
  dueDate       DateTime
  depositDate   DateTime?
  // Clear/bounce (account transaction) date.
  acctTransDate DateTime?
  bounceCharges Float?
  // SELF | PARTY (only when bounced).
  chargesPaidBy String?
  // Bounced cheque being re-deposited (legacy IS CHEQUE REPRESENT).
  isRepresent   Boolean   @default(false)
  comments      String?
  // PENDING | DEPOSITED | CLEARED | BOUNCED.
  status        String    @default("PENDING")
  userName      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([dueDate])
  @@index([customerId])
  @@index([chequeNo])
  @@map("cheques")
}

// ── Accounts: Receivables subledger (Payment / Opening Balance) ──────────────
// Ported from the legacy PaymentForm accounting tables. Invoices being paid are
// CONFIRMED challans (b = bank/billed portion, c = cash portion). The three legacy
// "…Summary" Access views are computed in the service layer as aggregations of
// these tables (a challan's pending = b/c minus the receipts allocated to it; an
// advance's balance = its amount minus receipts that reference it; opening pending
// = opening entries minus opening clearances).

/// Master ledger — one row per receipt voucher (legacy ACCT LEDGER). Voucher no is
/// RN/<serial> (agent) or R/<serial> style; source of the running voucher number.
model AcctLedger {
  id           Int      @id @default(autoincrement())
  voucherNo    String
  transDate    DateTime
  customerName String
  custId       Int      @default(0)
  agentName    String?
  particulars  String?
  voucherType  String   @default("RECEIPT")
  transMode    String // BANK | CHEQUE | CASH
  bankDebit    Float    @default(0)
  cashDebit    Float    @default(0)
  bankCredit   Float    @default(0)
  cashCredit   Float    @default(0)
  transRemarks String?
  userName     String?
  createdAt    DateTime @default(now())

  @@index([custId])
  @@index([voucherNo])
  @@index([transDate])
  @@map("acct_ledger")
}

/// Receipt allocation lines (legacy ACCT PAYMENT RECEIPT). One row per (invoice,
/// funding source). refRecId links to the voucher (fresh receipt) or to an advance
/// REF ID (when an old advance funded the allocation). modeOfAdj = AUTOMATIC/AGST
/// REF/ADVANCE.
model AcctPaymentReceipt {
  id                Int      @id @default(autoincrement())
  refId             String
  recDate           DateTime
  invNo             String
  customerName      String
  custId            Int
  recType           String   @default("RECEIPT")
  recAmt            Float
  payMode           String
  bankName          String?
  chequeNo          String?
  cashTransLocation String?
  cashRecBy         String?
  modeOfAdj         String?
  // Voucher no (fresh receipt) OR advance REF ID (advance-funded allocation).
  refRecId          String?
  createdAt         DateTime @default(now())

  @@index([custId])
  @@index([invNo])
  @@index([refRecId])
  @@index([recDate])
  @@map("acct_payment_receipt")
}

/// On-account / advance balances (legacy ACCT PARTY ADVANCE). Consumed FIFO by
/// receipts whose refRecId = this refId. takeAccOn = PARTY | AGENT.
model AcctPartyAdvance {
  id                Int      @id @default(autoincrement())
  refId             String
  recDate           DateTime
  custId            Int
  customerName      String
  agentName         String?
  bankAmt           Float    @default(0)
  cashAmt           Float    @default(0)
  payMode           String
  bankName          String?
  chequeNo          String?
  cashTransLocation String?
  cashRecBy         String?
  recType           String   @default("RECEIPT")
  // Originating voucher no.
  refRecId          String?
  takeAccOn         String? // PARTY | AGENT
  createdAt         DateTime @default(now())

  @@index([custId])
  @@index([refId])
  @@index([recDate])
  @@map("acct_party_advance")
}

/// Opening balances + their clearances (legacy ACCT OPENING TRANS). kind = OPENING
/// (entered on the Opening Balance form, with drCr = DEBIT/CREDIT) or CLEARANCE
/// (written when a receipt clears opening pending, linked via refRecId = voucher).
/// A DEBIT opening = customer owes us (cleared by receipts); CREDIT = we owe them.
model AcctOpeningTrans {
  id           Int      @id @default(autoincrement())
  kind         String   @default("OPENING") // OPENING | CLEARANCE
  customerName String
  custId       Int
  transDate    DateTime
  bankAmt      Float    @default(0)
  cashAmt      Float    @default(0)
  drCr         String? // DEBIT | CREDIT (OPENING rows only)
  // Voucher no that cleared this opening (CLEARANCE rows only).
  refRecId     String?
  remarks      String?
  userName     String?
  createdAt    DateTime @default(now())

  @@index([custId])
  @@index([kind])
  @@index([transDate])
  @@map("acct_opening_trans")
}

/// Sales discount granted against a pending invoice (legacy ACCT PARTY DISCOUNT).
/// Reduces the invoice's BANK (b) or CASH (c) outstanding, exactly like a receipt:
/// pending = amount − Σ(receipts) − Σ(discounts). Each save also posts a matching
/// SALES DISCOUNT voucher (SD/<id>) to AcctLedger as a credit on the mode's bucket.
model AcctPartyDiscount {
  id           Int      @id @default(autoincrement())
  disDate      DateTime
  invNo        String
  customerName String
  custId       Int
  // Snapshot of the invoice's B (BANK) or C (CASH) amount at discount time.
  invAmt       Float    @default(0)
  disAmt       Float
  // BANK | CASH — which bucket this discount settles.
  billType     String
  // Linked ledger voucher (SD/<id>); kept so edit/delete can update/remove it.
  voucherNo    String?
  userName     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([invNo])
  @@index([custId])
  @@index([billType])
  @@map("acct_party_discount")
}
