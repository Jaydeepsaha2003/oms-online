// OMS data model — SQLite.
// Run `npm run db:migrate` to create/update tables, `npm run db:seed` to load
// the permission catalog, system roles and the bootstrap admin user.
//
// SQLite notes (vs MySQL/Postgres): no native enums, no Json type, no native
// type attributes (@db.Text). So `status` is a validated String, `metadata` /
// `Setting.value` hold JSON-serialized strings. To move to MySQL/Postgres later:
// change the provider below, restore an enum for status and `Json` columns, and
// re-migrate.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Identity & access control ───────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  // Optional 4–6 digit quick-login PIN (bcrypt-hashed). Null = PIN login disabled.
  pinHash      String?
  // One of: 'active' | 'disabled' | 'invited' (enforced by the API via class-validator).
  status       String   @default("active")
  // Bumping tokenVersion invalidates every outstanding access token for the user.
  tokenVersion Int      @default(0)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles         UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@index([status])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  // Stable machine name, e.g. 'super_admin'.
  name        String   @unique
  label       String
  description String?
  // System roles cannot be deleted from the UI.
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id        String   @id @default(cuid())
  // Permission key, e.g. 'order:create'.
  key       String   @unique
  resource  String
  action    String
  label     String
  group     String
  createdAt DateTime @default(now())

  roles RolePermission[]

  @@index([resource])
  @@map("permissions")
}

// Explicit join: User <-> Role (kept explicit so we can add assignedAt/assignedBy later).
model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// Explicit join: Role <-> Permission.
model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

// Hashed refresh tokens enable rotation + server-side revocation (logout / "log out everywhere").
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  userAgent String?
  ip        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ── Audit trail: who did what, when, from where ─────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userEmail  String?
  action     String
  resource   String
  resourceId String?
  description String?
  method     String?
  path       String?
  statusCode Int?
  ip         String?
  userAgent  String?
  // JSON-serialized before/after snapshot (SQLite has no native Json type).
  metadata   String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resource])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ── App settings (key/value, surfaced on the Settings screen) ───────────────

model Setting {
  key       String   @id
  // JSON-serialized value (SQLite has no native Json type).
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ── Sales: Customers & Transporters ─────────────────────────────────────────

model Transporter {
  // Integer PK to match the legacy TID and ease data import.
  id        Int      @id @default(autoincrement())
  // Auto-generated human-readable code (e.g. TRN-00001). Set by the API on create;
  // never required on import (it is derived server-side), shown on export.
  code      String?  @unique
  name      String   @unique
  packing   Float?
  freight   Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers  Customer[]
  transRates TransRate[]

  @@map("transporters")
}

// Sales agents (used when partySource = AGENT). Maintained as its own master so
// agents can be added on the fly from the customer form and tracked with timestamps.
model Agent {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  contactNo String?
  state     String?
  city      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agents")
}

model Customer {
  // Integer PK to match the legacy CUSTOMER.ID and ease data import.
  id            Int      @id @default(autoincrement())
  // Auto-generated human-readable code (e.g. CUST-00001). Set by the API on create;
  // never required on import (it is derived server-side), shown on export.
  code          String?  @unique
  partySource   String?
  agentName     String?
  category      String?
  partyName     String?
  billingRate   Float?
  // FK to Transporter; transportName/packing/freight are kept as a snapshot too
  // (the legacy form stored them on the customer row).
  transporterId Int?
  transportName String?
  bagName       String?
  packing       Float?
  freight       Float?
  boxRate       Int?
  creditPeriod  Int?
  city          String?
  state         String?
  region        String?
  mobile        String?
  email         String?
  brand         String?
  billRatePc    Float?
  payBy         String?
  // TDS: whether tax is deducted at source for this customer, and at what %.
  tdsApplicable Boolean  @default(false)
  tdsPercent    Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transporter Transporter? @relation(fields: [transporterId], references: [id], onDelete: SetNull)
  gstRates    GstRate[]
  transRates  TransRate[]
  rateOverrides    CustomerRate[]
  logoRestrictions CustomerLogoRestriction[]

  @@index([partyName])
  @@index([agentName])
  @@index([category])
  @@index([transporterId])
  @@map("customers")
}

// ── Customer "Special Rates" (legacy Form10) ──────────────────────────────────
// A per-customer rate DELTA added on top of the base product / design rate. The
// effective rate is resolved most-specific-first (ITEM → SUBCATEGORY → CATEGORY);
// only the first matching level applies. Replaces the 6 legacy tables
// (SPRODUCT/SCSPRODUCT/SCPRODUCT for products, SDESIGN/SCSDESIGN/SCDESIGN for
// designs) with one table keyed by (kind, scope). Unused levels are stored as ''
// (not null) so the composite unique key works on SQLite.
model CustomerRate {
  id          Int      @id @default(autoincrement())
  customerId  Int
  // 'PRODUCT' (adjusts the product rate) or 'DESIGN' (adjusts the design rate).
  kind        String
  // 'CATEGORY' | 'SUBCATEGORY' | 'ITEM' (specificity level).
  scope       String
  category    String
  subCategory String   @default("") // '' when scope = CATEGORY
  // Product name (kind PRODUCT) or design type (kind DESIGN); '' unless scope = ITEM.
  target      String   @default("")
  // Rate delta — may be negative (a discount).
  rate        Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, kind, scope, category, subCategory, target])
  @@index([customerId])
  @@map("customer_rates")
}

// A per-customer logo restriction: the logo is NOT ALLOWED for the given category
// (or category + sub-category). Replaces SP_CATEGORY_LOGO / SP_SUBCATEGORY_LOGO.
model CustomerLogoRestriction {
  id          Int      @id @default(autoincrement())
  customerId  Int
  // 'CATEGORY' | 'SUBCATEGORY'.
  scope       String
  category    String
  subCategory String   @default("") // '' when scope = CATEGORY
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, scope, category, subCategory])
  @@index([customerId])
  @@map("customer_logo_restrictions")
}

/// Audit trail of GST / transport rate changes so past rates stay visible.
/// One row per change (old -> new). `kind` is 'GST' or 'TRANS'.
model RateHistory {
  id            Int      @id @default(autoincrement())
  kind          String
  customerName  String
  category      String
  type          String? // transport only
  transportName String? // transport only
  oldRate       Int?
  newRate       Int?
  changedByName String?
  changedAt     DateTime @default(now())

  @@index([kind, customerName, category])
  @@index([changedAt])
  @@map("rate_history")
}

// Per-customer, per-product-category GST rate.
model GstRate {
  id           Int      @id @default(autoincrement())
  customerId   Int?
  // Stable customer code (e.g. CUST-00001) — the fast link to the customer master.
  customerCode String?
  customerName String
  // Product category (legacy PCATEGORY), stored uppercase.
  category     String
  rate         Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([customerName, category])
  @@index([customerId])
  @@index([customerCode])
  @@map("gst_rates")
}

// Per-customer transport rate, keyed by category + type + transporter.
model TransRate {
  id            Int      @id @default(autoincrement())
  customerId    Int?
  // Stable customer code (e.g. CUST-00001) — the fast link to the customer master.
  customerCode  String?
  customerName  String
  category      String
  type          String
  transporterId Int?
  transportName String?
  rate          Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer    Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  transporter Transporter? @relation(fields: [transporterId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([customerCode])
  @@index([transporterId])
  @@map("trans_rates")
}

// ── Catalog: Products, Designs & Combinations ───────────────────────────────

model Product {
  id          Int      @id @default(autoincrement())
  // Auto-generated code (e.g. PRD-00001).
  code        String?  @unique
  category    String
  subCategory String
  product     String
  size        Float?
  weight      Float?
  pcs         Float?
  rate        Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // A product is uniquely identified by category + sub-category + product + size.
  @@unique([category, subCategory, product, size])
  @@index([category])
  @@index([product])
  @@map("products")
}

model Design {
  id          Int      @id @default(autoincrement())
  // Auto-generated code (e.g. DSG-00001).
  code        String?  @unique
  category    String
  subCategory String
  designType  String
  cost        Float?
  rate        Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  combinationLinks CombinationDesign[]

  @@unique([category, subCategory, designType])
  @@index([category])
  @@map("designs")
}

// Lookup: maps a design-type code to one or more human-readable names.
// A single code can have several names (one-to-many), so the natural key is the
// (designType, designName) pair, not the code alone.
model DesignName {
  id         Int      @id @default(autoincrement())
  designType String
  designName String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([designType, designName])
  @@index([designType])
  @@map("design_names")
}

model Combination {
  id        Int      @id @default(autoincrement())
  // Auto-generated code (e.g. CMB-00001).
  code      String?  @unique
  // Display name, auto-built by joining the component design types (editable).
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  designLinks CombinationDesign[]

  @@map("combinations")
}

// A combination is built from one or more designs. The link lets us recompute
// the combination's cost/rate whenever a constituent design's cost changes.
model CombinationDesign {
  combinationId Int
  designId      Int

  combination Combination @relation(fields: [combinationId], references: [id], onDelete: Cascade)
  design      Design      @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@id([combinationId, designId])
  @@index([designId])
  @@map("combination_designs")
}

// ── Orders ──────────────────────────────────────────────────────────────────

/// A sales order header. One order has many line items.
model Order {
  id             Int       @id @default(autoincrement())
  // Auto-generated human-readable order number (e.g. ORD-00001).
  code           String?   @unique
  // Customer's purchase-order number (free text, optional).
  poNumber       String?
  customerId     Int?
  customerName   String
  agentName      String?
  category       String? // e.g. SALES
  orderDate      DateTime  @default(now())
  completionDate DateTime?
  completionDay  Int?
  priority       String? // URGENT / NORMAL
  status         String    @default("PENDING") // CONFIRMED / PENDING / CANCELLED
  ordType        String    @default("SALES ORDER")
  comment        String?
  userName       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  items OrderItem[]

  // Set when this order was created by converting a quotation.
  fromQuotation Quotation? @relation("OrderFromQuotation")
  dispatches    Dispatch[]

  @@index([customerId])
  @@index([status])
  @@index([orderDate])
  @@map("orders")
}

/// A sales quotation — same shape as an order, with its own QUO-##### numbering
/// and a lifecycle: DRAFT/SENT → CONVERTED (to an order) or CANCELLED (with a
/// tracked reason for analysis).
model Quotation {
  id             Int       @id @default(autoincrement())
  code           String?   @unique // QUO-#####
  poNumber       String?
  customerId     Int?
  customerName   String
  agentName      String?
  category       String?
  quotationDate  DateTime  @default(now())
  completionDate DateTime?
  completionDay  Int?
  priority       String?
  status         String    @default("DRAFT") // DRAFT / SENT / CONVERTED / CANCELLED
  ordType        String    @default("QUOTATION")
  comment        String?
  userName       String?

  // "Sent to customer" tracking.
  sentAt     DateTime?
  sentByName String?

  // Conversion tracking — links to the order this quotation became.
  convertedOrderId Int?      @unique
  convertedOrder   Order?    @relation("OrderFromQuotation", fields: [convertedOrderId], references: [id])
  convertedAt      DateTime?
  // How it was converted: DIRECT (as-is) or EDITED (changed first).
  convertMode      String?

  // Cancellation tracking — why it was cancelled, for analysis.
  cancelReason    String?
  cancelNote      String?
  cancelledAt     DateTime?
  cancelledByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items QuotationItem[]

  @@index([customerId])
  @@index([status])
  @@index([quotationDate])
  @@map("quotations")
}

/// A single line item on a quotation (mirrors OrderItem).
model QuotationItem {
  id          Int      @id @default(autoincrement())
  quotationId Int
  pCategory   String?
  subCategory String?
  product     String?
  design      String?
  productName String?
  designType  String?
  psize       Float?
  bags        Float?
  pcs         Float?
  gram        Float?
  box         Float?
  productRate Float?
  designRate  Float?
  rate        Float?
  calField    String?
  priority    String?
  ordType     String?
  comment     String?
  createdAt   DateTime @default(now())

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@map("quotation_items")
}

/// A single line item on an order (a product × design + quantities + rates).
model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  pCategory   String? // product category (GLASS / CUP / …)
  subCategory String?
  product     String?
  design      String?
  productName String? // composite display name (e.g. "10 PLAIN")
  designType  String?
  psize       Float?
  bags        Float?
  pcs         Float?
  gram        Float?
  box         Float?
  productRate Float?
  designRate  Float?
  rate        Float? // total = productRate + designRate
  calField    String? // pricing unit: KGS / PCS
  priority    String? // URGENT / NORMAL (per line item)
  ordType     String? // order type (e.g. SALES ORDER)
  comment     String?
  createdAt   DateTime @default(now())

  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dispatches Dispatch[]

  @@index([orderId])
  @@map("order_items")
}

/// A single dispatch (shipment) of an order line — partial or full. The pending
/// quantity of a line = ordered − Σ(dispatched). Mirrors the legacy DispatchTbl.
model Dispatch {
  id          Int     @id @default(autoincrement())
  code        String? @unique // DSP-#####
  orderItemId Int
  orderId     Int
  orderCode   String? // the parent order's human code (snapshot)

  // Snapshot of the line at dispatch time.
  customerId   Int?
  customerName String
  agentName    String?
  category     String?
  pCategory    String?
  subCategory  String?
  product      String?
  productName  String?
  designType   String?
  psize        Float?
  priority     String?
  calField     String?
  ordType      String?
  productRate  Float?
  designRate   Float?
  rate         Float?

  // Dispatched quantities.
  bags Float?
  pcs  Float?
  gram Float?
  box  Float?

  dispatchStatus String   @default("PARTIAL") // PARTIAL / FULL
  dispatchDate   DateTime @default(now())
  comment        String?
  supItem        String?
  userName       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([orderId])
  @@index([dispatchStatus])
  @@map("dispatches")
}

// ── Challan / Tax-Invoice (legacy PendChallan + Form14) ───────────────────────
// A challan is a tax invoice built from one customer's dispatched-but-not-yet-
// challaned lines. Header (InvTbl) + items (ChallanTbl). Pricing engine (freight/
// packing/pouch/GST/half-bill/TCS) + PDF print land in Phase 2.
model Challan {
  id              Int       @id @default(autoincrement())
  // Human invoice number, e.g. "SSS/26-27/01" (legacy InvNo).
  code            String    @unique
  prefix          String?
  invDate         DateTime  @default(now())
  invTime         String?
  customerId      Int?
  customerName    String
  billingAddress  String?
  shippingAddress String?
  category        String?
  paymentTerm     Int?
  dueDate         DateTime?
  transName       String?
  // Charges & totals (computed by the Phase-2 pricing engine).
  packing         Float?
  freight         Float?
  pouch           Float?
  tcs             Float?
  // TDS deducted at source (when the party is TDS-applicable): amount + the % used.
  tds             Float?
  tdsPercent      Float?
  tax             Float? // GST amount
  total           Float?
  b               Float? // billed portion
  c               Float? // balance (total - b)
  remarks         String?
  gst             Float? // GST rate %
  freightRate     Float?
  packingRate     Float?
  billingRate     Float?
  bpcRate         Float?
  noBill          Boolean   @default(false)
  transaction     String    @default("SALES INVOICE")
  // CONFIRMED / CANCELLED.
  challanStatus   String    @default("CONFIRMED")
  userName        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  items ChallanItem[]

  @@index([customerName])
  @@index([invDate])
  @@map("challans")
}

model ChallanItem {
  id          Int      @id @default(autoincrement())
  challanId   Int
  // Source dispatch line (null/0 for SCRAP or manual rows). Plain int — used to
  // decide which dispatches are still "pending challan".
  dispatchId  Int?
  productName String?
  design      String?
  bags        Float?
  pcs         Float?
  kgs         Float?
  box         Float?
  unit        String?
  price       Float?
  amount      Float?
  pCategory   String?
  comment     String?
  userName    String?
  createdAt   DateTime @default(now())

  challan Challan @relation(fields: [challanId], references: [id], onDelete: Cascade)

  @@index([challanId])
  @@index([dispatchId])
  @@map("challan_items")
}

/// User-editable option lists (e.g. completion-day choices, order types),
/// grouped by `group`. Managed from the Settings page.
model OrderOption {
  id        Int      @id @default(autoincrement())
  group     String // COMPLETION_DAYS / ORDER_TYPE / …
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([group, value])
  @@index([group])
  @@map("order_options")
}

/// Singleton key/value app configuration (e.g. company name, company logo data URL).
model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_config")
}
