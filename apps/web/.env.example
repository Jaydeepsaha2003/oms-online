# ── apps/web environment ─────────────────────────────────────────────────────
# Copy to `apps/web/.env`. Only VITE_-prefixed vars are exposed to the browser.

# Leave VITE_API_URL unset to auto-target the API on whatever host the app is
# opened from (works on localhost and from other devices on the LAN). Set it only
# to pin a specific absolute URL.
# VITE_API_URL=http://localhost:4000/api

# Port the API listens on (used to build the API URL from the current host).
VITE_API_PORT=4000
VITE_APP_NAME=OMS
