# ── apps/web environment ──────────────────────────────────────────────────────
# Copy to `apps/web/.env`. Only VITE_-prefixed vars are exposed to the browser.

# Leave VITE_API_URL unset so the app calls /api on its own origin and the Vite
# dev/preview server proxies it to the Nest API (http://localhost:4000). This
# works on localhost, over HTTPS, and from other devices on the LAN. Set it only
# to bypass the proxy and pin a specific absolute URL.
# VITE_API_URL=http://localhost:4000/api

VITE_APP_NAME=OMS